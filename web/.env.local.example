# From Supabase: Project Settings -> API.
#
# The URL is not secret. Either name works — NEXT_PUBLIC_ matches the
# Next.js convention if you also want client components to use it later.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
#
# Service role key — server-only, bypasses RLS. MUST NOT be prefixed with
# NEXT_PUBLIC_ or it ends up in the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

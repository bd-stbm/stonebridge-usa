# From Supabase: Project Settings -> API.
#
# The URL is not secret. NEXT_PUBLIC_ prefix lets it ship to the browser
# (Supabase Auth needs the URL on the client).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Anon (publishable) key — safe to expose in the browser. RLS gates row access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role key — server-only, bypasses RLS. Not used by the dashboard
# (which now goes through the user's session), but kept for future admin
# server actions. MUST NOT be prefixed with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
